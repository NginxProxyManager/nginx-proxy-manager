{
	"operationId": "getJob",
	"summary": "Get async job status",
	"tags": [
		"jobs"
	],
	"security": [
		{
			"bearerAuth": []
		}
	],
	"description": "Returns status and result metadata for one background job by id.",
	"parameters": [
		{
			"in": "path",
			"name": "jobID",
			"schema": {
				"type": "integer",
				"minimum": 1
			},
			"required": true,
			"description": "Job ID",
			"example": 1
		}
	],
	"responses": {
		"200": {
			"description": "OK",
			"content": {
				"application/json": {
					"example": {
						"id": 1,
						"created_on": "2026-06-05T06:20:47.000Z",
						"modified_on": "2026-06-05T06:20:47.000Z",
						"owner_user_id": 1,
						"type": "certificate.create",
						"status": "pending",
						"payload": {},
						"result": null,
						"error": null,
						"finished_on": null
					},
					"schema": {
						"$ref": "../../../components/job-object.json"
					}
				}
			}
		}
	}
}
