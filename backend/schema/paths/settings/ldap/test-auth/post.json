{
	"operationId": "testLdapAuth",
	"summary": "Test LDAP authentication",
	"tags": ["settings"],
	"security": [
		{
			"bearerAuth": ["admin"]
		}
	],
	"requestBody": {
		"description": "Credentials to test against the LDAP server",
		"required": true,
		"content": {
			"application/json": {
				"schema": {
					"type": "object",
					"required": ["username", "password"],
					"additionalProperties": true,
					"properties": {
						"username": {
							"type": "string",
							"minLength": 1,
							"example": "jsmith"
						},
						"password": {
							"type": "string",
							"minLength": 1,
							"example": "hunter2"
						},
						"serverUrl": {
							"type": "string",
							"example": "ldap://dc.example.com"
						},
						"bindDN": {
							"type": "string",
							"example": "cn=svc,dc=example,dc=com"
						},
						"bindPassword": {
							"type": "string",
							"example": "s3cr3t"
						},
						"searchBase": {
							"type": "string",
							"example": "dc=example,dc=com"
						},
						"userAttribute": {
							"type": "string",
							"example": "uid"
						}
					}
				}
			}
		}
	},
	"responses": {
		"200": {
			"description": "200 response",
			"content": {
				"application/json": {
					"examples": {
						"success": {
							"value": {
								"success": true,
								"message": "Authentication successful for \"John Smith\"",
								"user": {
									"dn": "uid=jsmith,ou=people,dc=example,dc=com",
									"username": "jsmith",
									"email": "jsmith@example.com",
									"displayName": "John Smith"
								}
							}
						},
						"failure": {
							"value": {
								"success": false,
								"message": "Invalid credentials"
							}
						}
					}
				}
			}
		}
	}
}
