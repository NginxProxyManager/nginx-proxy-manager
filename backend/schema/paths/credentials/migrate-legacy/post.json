{
	"operationId": "migrateLegacyCredentials",
	"summary": "Migrate plaintext DNS credentials from certificates into the vault",
	"tags": ["credentials"],
	"security": [{ "bearerAuth": ["credentials.manage"] }],
	"requestBody": {
		"content": {
			"application/json": {
				"schema": {
					"type": "object",
					"additionalProperties": false,
					"properties": {
						"dry_run": { "type": "boolean" }
					}
				}
			}
		}
	},
	"responses": {
		"200": {
			"description": "OK",
			"content": {
				"application/json": {
					"schema": {
						"type": "object",
						"required": ["dry_run", "count", "results"],
						"properties": {
							"dry_run": { "type": "boolean" },
							"count": { "type": "integer" },
							"results": {
								"type": "array",
								"items": { "type": "object" }
							}
						}
					}
				}
			}
		}
	}
}
