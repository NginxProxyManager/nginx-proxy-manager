{
	"operationId": "updateLdapSettings",
	"summary": "Update LDAP configuration",
	"tags": ["settings"],
	"security": [
		{
			"bearerAuth": ["admin"]
		}
	],
	"requestBody": {
		"description": "LDAP Configuration Payload",
		"required": true,
		"content": {
			"application/json": {
				"schema": {
					"type": "object",
					"additionalProperties": false,
					"minProperties": 1,
					"properties": {
						"serverUrl": {
							"type": "string",
							"minLength": 1,
							"pattern": "^ldaps?://",
							"example": "ldap://dc.example.com"
						},
						"bindDN": {
							"type": "string",
							"example": "cn=svc,dc=example,dc=com"
						},
						"bindPassword": {
							"type": "string",
							"example": "s3cr3t"
						},
						"searchBase": {
							"type": "string",
							"minLength": 1,
							"example": "dc=example,dc=com"
						},
						"userFilter": {
							"type": "string",
							"example": "(objectClass=person)"
						},
						"groupDN": {
							"type": "string",
							"example": "ou=groups,dc=example,dc=com"
						},
						"userAttribute": {
							"type": "string",
							"enum": ["uid", "sAMAccountName", "mail", "userPrincipalName"],
							"example": "uid"
						},
						"adminGroup": {
							"type": "string",
							"example": "cn=npmadmins,ou=groups,dc=example,dc=com"
						},
						"userGroup": {
							"type": "string",
							"example": "cn=npmusers,ou=groups,dc=example,dc=com"
						},
						"enabled": {
							"type": "boolean",
							"example": false
						},
						"tlsVerify": {
							"type": "boolean",
							"example": true
						},
						"starttls": {
							"type": "boolean",
							"example": false
						}
					}
				}
			}
		}
	},
	"responses": {
		"200": {
			"description": "200 response",
			"content": {
				"application/json": {
					"examples": {
						"default": {
							"value": {
								"id": 1,
								"serverUrl": "ldap://dc.example.com",
								"bindDN": "cn=svc,dc=example,dc=com",
								"bindPassword": "••••••",
								"searchBase": "dc=example,dc=com",
								"userFilter": "",
								"groupDN": "ou=groups,dc=example,dc=com",
								"userAttribute": "uid",
								"adminGroup": "cn=npmadmins,ou=groups,dc=example,dc=com",
								"userGroup": "cn=npmusers,ou=groups,dc=example,dc=com",
								"enabled": false,
								"tlsVerify": true,
								"starttls": false
							}
						}
					}
				}
			}
		}
	}
}
