# Managed by Ansible — {{ npm_test_install_dir }}
services:
  app:
    image: "{{ npm_test_image }}"
    container_name: nginx-proxy-manager
    restart: unless-stopped
    ports:
      - "80:80"
      - "81:81"
      - "443:443"
    environment:
      # Test VM / Docker often has no IPv6; avoids nginx listen [::]:* errors.
      DISABLE_IPV6: "true"
    volumes:
      - ./data:/data
      - ./letsencrypt:/etc/letsencrypt
