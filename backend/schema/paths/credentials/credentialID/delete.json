{
	"operationId": "deleteCredential",
	"summary": "Delete a stored DNS credential",
	"tags": [
		"credentials"
	],
	"security": [
		{
			"bearerAuth": [
				"credentials.manage"
			]
		}
	],
	"description": "Deletes a stored DNS credential from the vault.",
	"parameters": [
		{
			"in": "path",
			"name": "credentialID",
			"schema": {
				"type": "integer",
				"minimum": 1
			},
			"required": true,
			"description": "Credential ID",
			"example": 1
		}
	],
	"responses": {
		"200": {
			"description": "OK",
			"content": {
				"application/json": {
					"schema": {
						"type": "boolean"
					}
				}
			}
		}
	}
}
