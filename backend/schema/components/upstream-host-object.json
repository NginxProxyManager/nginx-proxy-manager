{
	"type": "object",
	"description": "Upstream Host object",
	"required": ["id", "created_on", "modified_on", "owner_user_id", "name", "forward_scheme", "method", "meta"],
	"properties": {
		"id": {
			"type": "integer",
			"minimum": 1
		},
		"created_on": {
			"type": "string"
		},
		"modified_on": {
			"type": "string"
		},
		"owner_user_id": {
			"type": "integer",
			"minimum": 1
		},
		"is_deleted": {
			"type": "boolean"
		},
		"name": {
			"type": "string",
			"minLength": 1,
			"maxLength": 255
		},
		"forward_scheme": {
			"type": "string",
			"enum": ["http", "https"]
		},
		"method": {
			"type": "string",
			"enum": ["round_robin", "least_conn", "ip_hash"]
		},
		"meta": {
			"type": "object"
		},
		"proxy_host_count": {
			"type": "integer"
		},
		"servers": {
			"type": "array",
			"items": {
				"type": "object",
				"properties": {
					"id": { "type": "integer" },
					"created_on": { "type": "string" },
					"modified_on": { "type": "string" },
					"upstream_host_id": { "type": "integer" },
					"host": { "type": "string" },
					"port": { "type": "integer" },
					"weight": { "type": ["integer", "null"] },
					"meta": { "type": "object" }
				}
			}
		},
		"owner": {
			"$ref": "./user-object.json"
		}
	}
}
