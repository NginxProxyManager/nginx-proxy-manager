{
	"operationId": "createUpstreamHost",
	"summary": "Create an Upstream Host",
	"tags": ["upstream-hosts"],
	"security": [{ "bearerAuth": [] }],
	"requestBody": {
		"description": "Upstream Host Payload",
		"required": true,
		"content": {
			"application/json": {
				"schema": {
					"type": "object",
					"required": ["name", "servers"],
					"additionalProperties": false,
					"properties": {
						"name": {
							"type": "string",
							"minLength": 1,
							"maxLength": 255,
							"example": "my-upstream"
						},
						"forward_scheme": {
							"type": "string",
							"enum": ["http", "https"],
							"example": "http"
						},
						"method": {
							"type": "string",
							"enum": ["round_robin", "least_conn", "ip_hash"],
							"example": "round_robin"
						},
						"servers": {
							"type": "array",
							"minItems": 1,
							"items": {
								"type": "object",
								"required": ["host", "port"],
								"properties": {
									"host": {
										"type": "string",
										"minLength": 1,
										"maxLength": 255,
										"example": "10.0.0.1"
									},
									"port": {
										"type": "integer",
										"minimum": 1,
										"maximum": 65535,
										"example": 8080
									},
									"weight": {
										"type": "integer",
										"minimum": 1,
										"maximum": 100,
										"example": 1
									}
								}
							},
							"example": [
								{
									"host": "10.0.0.1",
									"port": 8080,
									"weight": 1
								}
							]
						},
						"meta": {
							"type": "object",
							"example": {}
						}
					}
				},
				"example": {
					"name": "my-upstream",
					"forward_scheme": "http",
					"method": "round_robin",
					"servers": [
						{
							"host": "10.0.0.1",
							"port": 8080,
							"weight": 1
						}
					]
				}
			}
		}
	},
	"responses": {
		"201": {
			"description": "201 response",
			"content": {
				"application/json": {
					"examples": {
						"default": {
							"value": {
								"id": 1,
								"created_on": "2025-10-30T01:12:05.000Z",
								"modified_on": "2025-10-30T01:12:05.000Z",
								"owner_user_id": 1,
								"name": "my-upstream",
								"forward_scheme": "http",
								"method": "round_robin",
								"meta": {},
								"proxy_host_count": 0,
								"owner": {
									"id": 1,
									"created_on": "2025-10-28T00:50:24.000Z",
									"modified_on": "2025-10-28T00:50:24.000Z",
									"is_disabled": false,
									"email": "jc@jc21.com",
									"name": "jamiec",
									"nickname": "jamiec",
									"avatar": "//www.gravatar.com/avatar/6193176330f8d38747f038c170ddb193?default=mm",
									"roles": ["admin"]
								}
							}
						}
					},
					"schema": {
						"$ref": "../../../components/upstream-host-object.json"
					}
				}
			}
		}
	}
}
