{
	"operationId": "createApiKey",
	"summary": "Create an API key",
	"tags": [
		"api-keys"
	],
	"security": [
		{
			"bearerAuth": []
		}
	],
	"description": "Creates a long-lived API key for automation. The raw key is returned once in the response and cannot be retrieved again.",
	"requestBody": {
		"required": true,
		"content": {
			"application/json": {
				"schema": {
					"type": "object",
					"required": [
						"name"
					],
					"properties": {
						"name": {
							"type": "string"
						},
						"permissions": {
							"type": "object"
						},
						"expires_on": {
							"type": [
								"string",
								"null"
							]
						}
					}
				}
			}
		}
	},
	"responses": {
		"201": {
			"description": "Created"
		}
	}
}
